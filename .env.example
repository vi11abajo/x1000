# x1000 Agent Configuration
# Copy to .env and fill in your values. NEVER commit .env.

# OKX profile name (must match a section in ~/.okx/config.toml)
OKX_PROFILE=live

# Trading instrument
INST_ID=BTC-USDT-SWAP

# Loop interval in seconds
LOOP_INTERVAL_SEC=30

# Risk limits
MAX_POSITION_USD=100
MAX_DAILY_LOSS_USD=50
MAX_LEVERAGE=10

# Kill switch (true/false)
KILL_SWITCH=false

# Telegram notifications
TG_BOT_TOKEN=your_bot_token_here
TG_CHAT_ID=your_chat_id_here

# Trading parameters
TD_MODE=isolated
TP_PERCENT=0
SL_PERCENT=0
TRAILING_CALLBACK=0

# AI API key (AWstore / Anthropic-compatible)
AWSTORE_API_KEY=sk-aw-your_api_key_here
